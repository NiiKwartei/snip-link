# ─────────────────────────────────────────────────
#  snip.link — Environment Configuration
# ─────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
BASE_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/sniplink?schema=public"

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SHORTEN_RATE_LIMIT_MAX=20

# URL Shortener
SHORT_CODE_LENGTH=6
CUSTOM_ALIAS_MIN_LENGTH=3
CUSTOM_ALIAS_MAX_LENGTH=30
DEFAULT_REDIRECT_STATUS=301

# GeoIP (optional — use MaxMind or ip-api)
GEOIP_API_KEY=

# Analytics
ANALYTICS_RETENTION_DAYS=365

# Redis (optional — for caching)
REDIS_URL=redis://localhost:6379
